# ======================================================================
# NEXTROLE — Configuration centralisée
# Copiez ce fichier en ".env" et remplissez les valeurs.
# Ne committez JAMAIS le fichier ".env" (déjà dans .gitignore).
# ======================================================================

# -----------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------
# URL du backend telle que vue depuis le navigateur client
# Local dev  : http://localhost:3005
# Production : https://nextrole.maashrees.fr/api  (ou http://localhost:3000 derrière nginx)
VITE_BACKEND_URI=http://localhost:3005

# URL du frontend (utilisée par le backend pour les headers CORS)
# Local dev  : http://localhost:5174
# Production : https://nextrole.maashrees.fr
FRONTEND_URL=http://localhost:5174

# -----------------------------------------------------------------------
# BACKEND — Serveur applicatif
# -----------------------------------------------------------------------
APP_PORT=3000
APP_HOST=localhost

# -----------------------------------------------------------------------
# MONGODB
# -----------------------------------------------------------------------
# Local (service Docker interne)  : mongodb
# Production (service infra-prod) : mongodb-prod
# VPS sans Docker                 : 172.17.0.1 ou host.docker.internal
DB_HOST=mongodb
DB_PORT=27017
DB_NAME=nextrole

# Credentials MongoDB (utilisés en mode production / infra-prod.yml)
MONGO_INITDB_ROOT_USERNAME=nextrole_admin
MONGO_INITDB_ROOT_PASSWORD=changeme_strong_password

# -----------------------------------------------------------------------
# SÉCURITÉ JWT & HACHAGE
# -----------------------------------------------------------------------
# Générez une clé forte : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_jwt_secret_here
SALT_ROUNDS=10

# -----------------------------------------------------------------------
# AVATARS
# -----------------------------------------------------------------------
BASE_AVATAR_URL=https://api.dicebear.com/9.x/avataaars-neutral/svg?seed=

# -----------------------------------------------------------------------
# MINIO — Data Lake (S3-compatible)
# -----------------------------------------------------------------------
# Local (service Docker interne)  : minio
# Production (service infra-prod) : minio-prod
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=nextrole_minio_user
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET_CV=cv-uploads
MINIO_BUCKET_OFFERS=job-offers

# Console d'administration MinIO (dev uniquement)
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------
# AIRFLOW — Orchestrateur de pipelines
# -----------------------------------------------------------------------
# Local (service Docker interne)  : postgres
# Production (service infra-prod) : postgres-prod
AIRFLOW_DB_HOST=postgres
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=changeme_airflow_password

# Clé de chiffrement Fernet pour Airflow
# Générez avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here

# Identifiants admin de l'interface Airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_airflow_admin
AIRFLOW_PORT=8085

# -----------------------------------------------------------------------
# AZURE DOCUMENT INTELLIGENCE — OCR
# -----------------------------------------------------------------------
AZURE_OCR_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OCR_KEY=your_azure_key_here
# Modèle à utiliser : prebuilt-read, prebuilt-document, prebuilt-layout...
AZURE_OCR_MODEL=prebuilt-document

# -----------------------------------------------------------------------
# RÉSEAU DOCKER (production uniquement)
# -----------------------------------------------------------------------
# Nom du réseau Docker externe partagé sur le VPS
# Créez-le manuellement : docker network create infra-network
INFRA_NETWORK=infra-network
