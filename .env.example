# ====== CONFIGURATION DOCKER GLOBALE ======
# Ce fichier centralise toutes les variables pour le Backend et le Frontend.
# Docker Compose lira automatiquement un fichier ".env" placé à la racine du projet.

# -- FRONTEND --
# L'URL où le frontend contactera le backend (injecté au build)
VITE_BACKEND_URI=http://localhost:3000
# Utilisé par le backend pour autoriser les requêtes CORS
FRONTEND_URL=http://localhost:5174

# -- MONGODB --
# En environnement Docker local, utilisez "host.docker.internal" si mongo tourne sur votre PC (en dehors de docker)
# Sur le VPS, utilisez l'IP du bridge (ex: 172.17.0.1) ou le nom du service mongo s'il est dans le même réseau docker.
DB_HOST=host.docker.internal
DB_PORT=27017
DB_NAME=nextrole

# -- SECURITE & APP --
JWT_SECRET=votre_secret_tres_long_ici
SALT_ROUNDS=10
BASE_AVATAR_URL=https://api.dicebear.com/9.x/avataaars-neutral/svg?seed=
